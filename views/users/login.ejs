<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">

<link href="https://fonts.googleapis.com/css2?family=Playfair+Display:wght@600;700&family=Inter:wght@400;500;600&display=swap" rel="stylesheet">

<title>Login | Wanderlust</title>

<script src="https://cdn.tailwindcss.com"></script>

<meta name="viewport" content="width=device-width, initial-scale=1.0">
</head>

<body class="bg-gray-50 flex items-center justify-center min-h-screen"
style="font-family:'Inter', sans-serif;">

<div class="bg-white shadow-lg rounded-xl p-8 w-[90%] max-w-md">

<h1 class="text-3xl mb-6 text-center"
style="font-family:'Playfair Display', serif;">
Welcome Back
</h1>

<!-- Flash Alerts -->
<% if(success && success.length > 0){ %>
<div class="mb-4 bg-green-100 border border-green-400 text-green-700 px-4 py-2 rounded">
<%= success[0] %>
</div>
<% } %>

<% if(error && error.length > 0){ %>
<div class="mb-4 bg-red-100 border border-red-400 text-red-700 px-4 py-2 rounded">
<%= error[0] %>
</div>
<% } %>

<form action="/login" method="POST" class="space-y-4">

<div>
<label class="block text-sm mb-1">Username</label>
<input 
name="username"
required
class="w-full border p-2 rounded focus:ring-2 focus:ring-red-400 focus:outline-none">
</div>

<div>
<label class="block text-sm mb-1">Password</label>
<input 
type="password"
name="password"
required
class="w-full border p-2 rounded focus:ring-2 focus:ring-red-400 focus:outline-none">
</div>

<button 
class="w-full bg-red-500 text-white py-2 rounded hover:bg-red-600 transition font-semibold">
Login
</button>

</form>

<p class="text-sm text-center mt-4">
New here?
<a href="/signup" class="text-red-500 font-medium hover:underline">
Create an account
</a>
</p>

</div>

</body>
</html>