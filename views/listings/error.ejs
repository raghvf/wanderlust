<% layout("layouts/boilerplate") %>

<div class="max-w-4xl mx-auto px-6 py-20">

<h2 class="text-4xl font-bold mb-10 tracking-tight text-center">
Something Went Wrong
</h2>

<div class="bg-white rounded-2xl shadow p-10 text-center space-y-6">

<h3 class="text-6xl font-bold text-red-500">
<%= err.statusCode || 500 %>
</h3>

<p class="text-gray-600 text-lg">
<%= err.message || "Unexpected error occurred." %>
</p>

<div class="flex justify-center gap-4 pt-6">

<a href="/"
class="bg-red-500 text-white px-6 py-3 rounded-lg hover:bg-red-600 transition font-semibold shadow">
Go Home
</a>

<a href="/listings"
class="border px-6 py-3 rounded-lg hover:bg-gray-100 transition">
Browse Listings
</a>

</div>

</div>

</div>